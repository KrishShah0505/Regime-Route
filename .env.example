# ── Database ──────────────────────────────────────────
DATABASE_URL=sqlite:///./quantregime.db

# ── API Server ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Backtest Defaults ─────────────────────────────────
DEFAULT_CAPITAL=100000.0
DEFAULT_COMMISSION=0.001      # 0.1% per trade
DEFAULT_SLIPPAGE=0.0005       # 0.05% per trade

# ── Data ──────────────────────────────────────────────
# yFinance is free — no key needed
# VIX ticker used as volatility proxy
VIX_TICKER=^VIX
DEFAULT_UNIVERSE=AAPL,MSFT,GOOGL,AMZN,META,NVDA,TSLA,JPM,BAC,GS,XOM,JNJ,UNH,PG,V
